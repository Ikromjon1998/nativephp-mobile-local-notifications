{
    "name": "ikromjon/nativephp-mobile-local-notifications",
    "description": "Local notifications plugin for NativePHP Mobile - schedule, cancel, and manage local notifications with channels, badges, sounds, and repeat intervals",
    "type": "nativephp-plugin",
    "license": "MIT",
    "keywords": [
        "nativephp",
        "mobile",
        "local-notifications",
        "notifications",
        "schedule",
        "reminders",
        "laravel"
    ],
    "require": {
        "php": "^8.3",
        "nativephp/mobile": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.28",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Ikromjon\\LocalNotifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ikromjon\\LocalNotifications\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ikromjon\\LocalNotifications\\LocalNotificationsServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "lint:check": "pint --test",
        "refactor": "rector process",
        "refactor:check": "rector process --dry-run",
        "check": [
            "@lint:check",
            "@refactor:check",
            "@analyse",
            "@test"
        ],
        "fix": [
            "@lint",
            "@refactor"
        ]
    }
}

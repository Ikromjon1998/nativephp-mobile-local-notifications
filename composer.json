{
    "name": "ikromjon/nativephp-mobile-local-notifications",
    "description": "Local notifications plugin for NativePHP Mobile - schedule, cancel, and manage local notifications with channels, badges, sounds, and repeat intervals",
    "type": "nativephp-plugin",
    "license": "MIT",
    "keywords": [
        "nativephp",
        "mobile",
        "local-notifications",
        "notifications",
        "schedule",
        "reminders",
        "laravel"
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ikromjon\\LocalNotifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ikromjon\\LocalNotifications\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ikromjon\\LocalNotifications\\LocalNotificationsServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse"
    }
}
